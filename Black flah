local frame = script.Parent

local blackFlashBtn = frame.BlackFlash
local blockBtn = frame.Block

local blockEnabled = false

blackFlashBtn.MouseButton1Click:Connect(function()
    game.ReplicatedStorage.BlackFlashEvent:FireServer()
end)

blockBtn.MouseButton1Click:Connect(function()
    blockEnabled = not blockEnabled

    if blockEnabled then
        blockBtn.Text = "Block: ON"
    else
        blockBtn.Text = "Block: OFF"
    end

    game.ReplicatedStorage.BlockEvent:FireServer(blockEnabled)
end)+------------------+
